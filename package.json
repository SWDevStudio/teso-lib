{
  "name": "teso-lib",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "postinstall": "node scripts/copy-sql-wasm.mjs",
    "copy:wasm": "node scripts/copy-sql-wasm.mjs",
    "rules:build": "node scripts/build-rules.mjs",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s \"lint:*\"",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/",
    "cap:sync": "npm run build-only && cap sync",
    "cap:copy": "npm run build-only && cap copy",
    "cap:android": "npm run cap:sync && cap open android",
    "cap:run": "npm run cap:sync && node scripts/run-android.mjs",
    "cap:apk": "npm run cap:sync && node scripts/build-apk.mjs",
    "cap:apk:release": "npm run cap:sync && node scripts/build-apk.mjs release",
    "electron:icon": "node scripts/make-icon.mjs",
    "electron:compile": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --target=node20 --format=cjs --external:electron --outdir=dist-electron --out-extension:.js=.cjs",
    "electron:build": "npm run build && npm run electron:compile",
    "electron:dev": "npm run electron:build && electron .",
    "electron:dist": "npm run electron:icon && npm run electron:build && electron-builder --win portable"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "8.1.0",
    "@capacitor/core": "^8.4.1",
    "@vueuse/core": "^14.3.0",
    "marked": "^18.0.5",
    "pinia": "^3.0.4",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@iconify-json/game-icons": "^1.2.4",
    "@iconify-json/lucide": "^1.2.114",
    "@tailwindcss/vite": "^4.3.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.2",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/tsconfig": "^0.9.1",
    "daisyui": "^5.5.23",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.69.0",
    "eslint-plugin-vue": "~10.9.2",
    "jeep-sqlite": "^2.8.0",
    "jiti": "^2.7.0",
    "mammoth": "^1.12.0",
    "node-html-parser": "^8.0.3",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.54.0",
    "oxlint": "~1.69.0",
    "sharp": "^0.35.2",
    "sql.js": "1.11.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.0",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  }
}
